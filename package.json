{
  "name": "@mantissaio/medusa-payment-wompi",
  "version": "1.0.0",
  "description": "Wompi El Salvador payment provider plugin for MedusaJS v2",
  "author": "Mantissa.io",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mantissaio/medusa-payment-wompi.git"
  },
  "homepage": "https://github.com/mantissaio/medusa-payment-wompi",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    ".medusa/server"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./*": "./.medusa/server/src/*.js"
  },
  "keywords": [
    "medusa",
    "plugin",
    "medusa-plugin-integration",
    "medusa-plugin-payment",
    "medusa-plugin",
    "medusa-v2",
    "wompi",
    "wompi-sv",
    "payment",
    "el-salvador"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "test": "jest --config jest.config.cjs --runInBand",
    "prepublishOnly": "medusa plugin:build"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "^2.12.5",
    "@medusajs/admin-shared": "^2.13.5",
    "@medusajs/cli": "^2.12.5",
    "@medusajs/framework": "^2.12.5",
    "@medusajs/icons": "^2.12.5",
    "@medusajs/medusa": "^2.12.5",
    "@medusajs/test-utils": "^2.12.5",
    "@medusajs/ui": "^4.0.21",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@swc/core": "1.15.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^30.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.2.11"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "^2.12.5",
    "@medusajs/cli": "^2.12.5",
    "@medusajs/framework": "^2.12.5",
    "@medusajs/icons": "^2.12.5",
    "@medusajs/medusa": "^2.12.5",
    "@medusajs/ui": "^4.0.21"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "zod": "^3.25.76"
  }
}
